    {
      "parameters": {
        "jsCode": "const text = $json.data;\n\nconst title =\n  text.match(/Title:\\s*(.*)/)?.[1]?.trim() || '';\n\nconst source_link =\n  text.match(/URL Source:\\s*(.*)/)?.[1]?.trim() || '';\n\nconst markdown =\n  text.match(/Markdown Content:\\s*([\\s\\S]*)/)?.[1]?.trim() || '';\n\nreturn [{\n  title,\n  source_link,\n  markdown\n}];"
      },
